# ─────────────────────────────────────────────────────────────
# Doyle Financial Planner — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is in .gitignore.
# ─────────────────────────────────────────────────────────────

# Anthropic API Key (for AI Advisor features — optional)
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Database path — do not change after first run
# The database file is stored in plaintext.
# DATA SECURITY: ensure /app/data is on an encrypted Unraid share or
# encrypted host filesystem. See README → "Data security".
DATABASE_URL=sqlite:////app/data/financial_planner.db

# CAD/USD exchange rate (update periodically)
FX_CAD_USD=1.3650

# ─────────────────────────────────────────────────────────────
# Security settings (safe defaults work for most setups)
# ─────────────────────────────────────────────────────────────

# Environment: "production" (default) disables /docs and /redoc.
# Set to "development" to enable interactive API docs.
APP_ENV=production

# CORS origins — comma-separated list of allowed request origins.
# The SPA and API run on the same domain so CORS is mainly cosmetic for this app.
# For a Cloudflare-tunnelled setup the localhost values below are fine.
# Add your public hostname here if you see CORS errors in the browser console.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:8080

# Trusted hostnames for Host-header injection prevention.
# Add your Cloudflare tunnel hostname here.
TRUSTED_HOSTS=localhost,127.0.0.1

# Set DOCS_ENABLED=1 to re-enable /docs and /redoc (development only).
DOCS_ENABLED=0

# ─────────────────────────────────────────────────────────────
# Debugging — remove after use
# ─────────────────────────────────────────────────────────────

# Set DEBUG_ENV=1 to:
#   • print all env vars (masked) at container startup
#   • enable the GET /api/debug/config endpoint
# Remove this line (or set to 0) once your issue is diagnosed.
# DEBUG_ENV=1
