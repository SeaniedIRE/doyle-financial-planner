# ─────────────────────────────────────────────────────────────
# Doyle Financial Planner — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to git.
# ─────────────────────────────────────────────────────────────

# Anthropic API Key (for AI Advisor features — optional, app works without it)
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Database path — do not change after first run
DATABASE_URL=sqlite:////app/data/financial_planner.db

# Current CAD/USD exchange rate (update periodically as rates change)
FX_CAD_USD=1.3650
