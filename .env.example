# Anthropic API Key (for AI Advisor features)
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Database path (do not change unless you know what you're doing)
DATABASE_URL=sqlite:////app/data/financial_planner.db

# Current CAD/USD exchange rate (update as rates change)
FX_CAD_USD=1.3650
